# Copy this file to .bazelrc.local for per-machine toolchain overrides.
# This file is not committed and is intended for host-specific setup.

# Example for Linux + swiftly where `swiftc`/`clang` in PATH are wrapper shims:
# 1) Find the active swiftly toolchain:
#    swiftly use
# 2) Set PATH so rules_swift autodiscovery finds the real swiftc first:
# common --repo_env=PATH=/home/<user>/.local/share/swiftly/toolchains/<toolchain>/usr/bin:/usr/local/bin:/usr/bin:/bin
#
# 3) Optionally pin real compiler binaries if needed:
# common --repo_env=CC=/usr/bin/clang
# common --repo_env=CXX=/usr/bin/clang++
# build --action_env=CC=/usr/bin/clang
# build --action_env=CXX=/usr/bin/clang++
