# Force proper formatting for Rust code
build --aspects=@rules_rust//rust:defs.bzl%rustfmt_aspect
build --output_groups=+rustfmt_checks

# Suppress warnings from selected external SwiftPM modules.
# Format: <target-label>=<comma-delimited-swiftcopts>
build --@build_bazel_rules_swift//swift:per_module_swiftcopt=@swiftpkg_swift_system//:SystemPackage.rspm=-suppress-warnings

# Keep MODULE.bazel.lock up to date automatically on every build.
common --lockfile_mode=update

# Per-machine overrides (ignored by git).
# Use this when local PATH has wrappers (for example, swiftly shims) and you
# need to point Bazel repo autoconfiguration at real compiler binaries.
try-import %workspace%/.bazelrc.local
