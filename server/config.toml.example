[providers.openai]
kind = "OpenAI"
url = "https://api.openai.com/v1"
token = "sk-..."

# OpenRouter is OpenAI-compatible but takes reasoning effort as a nested
# `reasoning: { effort }` object. Use kind = "OpenRouter" so the effort level
# (including "xhigh") is sent in the form OpenRouter expects.
[providers.openrouter]
kind = "OpenRouter"
url = "https://openrouter.ai/api/v1"
token = "sk-or-..."

[providers.anthropic]
kind = "Anthropic"
url = "https://api.anthropic.com/v1"
token = "sk-ant-..."

[providers.ollama]
kind = "Ollama"
url = "http://localhost:11434/v1"

[models.gpt_4_1]
slug = "gpt-4.1"
provider = "openai"
# Reasoning effort: "low", "medium", "high", or "xhigh". Omit to disable.
reasoning_effort = "high"
# Set when the model accepts image inputs. Enables attached images and the
# attach_image tool. Defaults to false.
vision = true

[models.claude_sonnet_4]
slug = "claude-sonnet-4-20250514"
provider = "anthropic"
reasoning_effort = "medium"

[models.llama]
slug = "llama3.2"
provider = "ollama"
# Omit reasoning_effort (or the legacy `thinking` flag) to disable reasoning.

# A model registered under the reserved name `embeddings` is used to embed text
# for the agent's memory palace, enabling semantic recall. It must point at an
# OpenAI- or Ollama-compatible provider. Without it, memory recall falls back to
# keyword search.
[models.embeddings]
slug = "text-embedding-3-small"
provider = "openai"

# A model registered under the reserved name `transcription` is used to convert
# voice input into text: the web UI's mic button and incoming Telegram voice
# messages are transcribed through it. It must point at an OpenAI-compatible
# provider exposing a Whisper-style `/v1/audio/transcriptions` endpoint. Without
# it, the mic button and Telegram voice transcription are disabled.
[models.transcription]
slug = "whisper-1"
provider = "openai"

[server]
# SQLite database path. Used when `db_url` (below) is unset.
db_path = "/tmp/server.db"
# Full database connection URL, taking precedence over `db_path`. Supports
# sqlite, postgres, and postgresql schemes. Can also be set via the
# STRIDE_DATABASE_URL environment variable.
#   db_url = "postgres://user:password@localhost:5432/stride"
listen_addr = "0.0.0.0:3000"
# Self-signup is closed by default; set this to true to explicitly enable it.
allow_registration = false
# Public base URL the server is reachable at. When set, image attachments are
# served to vision models via capability URLs under this host instead of being
# embedded inline as base64.
public_url = "https://stride.example.com"

# Set STRIDE_EMAIL_ENCRYPTION_KEY to a stable, high-entropy secret before users add IMAP accounts.
# It encrypts stored IMAP passwords and must remain stable across restarts and JWT key rotation.

[server.files]
keep_versions = 10

[server.files.local]
enabled = true
base = "/tmp/stride-files"

# Account linking uses the Telegram Login Widget (https://core.telegram.org/bots/telegram-login).
# Tell BotFather which domain hosts the widget with `/setdomain` (the host in `public_url`),
# otherwise Telegram refuses to render the login button.
[server.telegram]
bot_api_key = "123456:telegram-bot-token"
bot_username = "stride_bot"
webhook_secret = "change-this-webhook-secret"

# Linking a GitHub account uses a standard GitHub OAuth App. Register one at
# https://github.com/settings/developers with the authorization callback URL set
# to `{public_url}/api/settings/github/callback`. Setting client_id and
# client_secret activates the hosted GitHub MCP server for every linked user.
[server.github]
client_id = "Iv1.0123456789abcdef"
client_secret = "change-this-github-oauth-secret"
# Optional. OAuth scopes requested when linking; defaults to "repo read:org read:user".
# scopes = "repo read:org read:user"
# Optional. Override only for GitHub Enterprise Cloud; defaults to the official server.
# mcp_url = "https://api.githubcopilot.com/mcp/"

# Linking a Google account uses a standard OAuth 2.0 / OIDC client. Create one in
# the Google Cloud console (APIs & Services -> Credentials -> OAuth client ID,
# type "Web application") with the authorized redirect URI set to
# `{public_url}/api/settings/google/callback`, and enable the Calendar, Gmail,
# and Drive APIs for the project. Setting client_id and client_secret signs users
# in with Google; tools are only exposed once `mcp_url` points at a Google MCP
# server (there is no official hosted one).
[server.google]
client_id = "0123456789-abcdef.apps.googleusercontent.com"
client_secret = "change-this-google-oauth-secret"
# Required for any tools to load: the Streamable HTTP endpoint of a Google MCP server.
# mcp_url = "https://mcp.google.example.com/mcp"
# Optional. OAuth scopes requested when linking; defaults to OIDC identity plus
# Calendar, Gmail (modify), and Drive.
# scopes = "openid email profile https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/drive"

[server.ldap]
url = "ldap://localhost:389"
user_dn_template = "uid={username},ou=users,dc=example,dc=com"

[tools.web_search]
searxng_endpoint = "https://search.example.com"
searxng_request_delay_seconds = 5
brave_api_key = "BSA..."
include_arxiv = true
include_pubmed = true

[tools.firecrawl]
api_key = "fc-..."
api_url = "https://api.firecrawl.dev"

[mcp.deepwiki]
url = "https://mcp.deepwiki.com/mcp"

[mcp.internal]
url = "https://mcp.example.com/mcp"
token = "secret-token"
headers = { X-Tenant = "acme" }

[tools.python]
enabled = true
cache_dir = "/tmp/stride-execenv"
backend = "Eryx"
threads = 2
preinit = true
max_runtime_seconds = 30
max_memory_bytes = 134217728
network = "Blocked"
