[providers.openai]
kind = "OpenAI"
url = "https://api.openai.com/v1"
token = "sk-..."

# OpenRouter is OpenAI-compatible but takes reasoning effort as a nested
# `reasoning: { effort }` object. Use kind = "OpenRouter" so the effort level
# (including "xhigh") is sent in the form OpenRouter expects.
[providers.openrouter]
kind = "OpenRouter"
url = "https://openrouter.ai/api/v1"
token = "sk-or-..."

[providers.anthropic]
kind = "Anthropic"
url = "https://api.anthropic.com/v1"
token = "sk-ant-..."

[providers.ollama]
kind = "Ollama"
url = "http://localhost:11434/v1"

# Predefined models in this section are available to every user in the web UI
# and OpenAI-compatible API. Users can also add personal providers and models
# in Settings.
#
# Add a chat model by creating a new [models.<registry_key>] section. The
# registry key is what users select in the composer and what subagents receive
# as the `model` argument. Use letters, numbers, and underscores. Set
# display_name for the label shown in the UI; description appears in Settings.
#
# Reserved registry keys (do not use for chat): embeddings, transcription,
# title_generator, ocr, expert, explorer.
#
# Point one entry at [models.default] to control the composer default. When
# that section is missing, the first chat model in this file is aliased as
# `default`.
[models.default]
display_name = "GPT-4.1"
description = "Default OpenAI model for general chat and coding."
slug = "gpt-4.1"
provider = "openai"
reasoning_effort = "high"
vision = true

[models.gpt_4_1]
display_name = "GPT-4.1"
description = "Same model under an alternate registry key."
slug = "gpt-4.1"
provider = "openai"
# Reasoning effort: "low", "medium", "high", or "xhigh". Omit to disable.
reasoning_effort = "high"
# Set when the model accepts image inputs. Enables attached images and the
# attach_image tool. Defaults to false.
vision = true

[models.claude_sonnet_4]
display_name = "Claude Sonnet 4"
description = "Balanced Anthropic model for reasoning and writing."
slug = "claude-sonnet-4-20250514"
provider = "anthropic"
reasoning_effort = "medium"

[models.llama]
display_name = "Llama 3.2"
description = "Local Ollama model for offline or low-cost runs."
slug = "llama3.2"
provider = "ollama"
# Omit reasoning_effort (or the legacy `thinking` flag) to disable reasoning.

# A model registered under the reserved name `embeddings` is used to embed text
# for the agent's memory palace, enabling semantic recall. It must point at an
# OpenAI- or Ollama-compatible provider. Without it, memory recall falls back to
# keyword search.
[models.embeddings]
slug = "text-embedding-3-small"
provider = "openai"

# A model registered under the reserved name `transcription` is used to convert
# voice input into text: the web UI's mic button and incoming Telegram voice
# messages are transcribed through it. It must point at an OpenAI-compatible
# provider exposing a Whisper-style `/v1/audio/transcriptions` endpoint. Without
# it, the mic button and Telegram voice transcription are disabled.
[models.transcription]
slug = "whisper-1"
provider = "openai"

# A model registered under the reserved name `ocr` powers the `ocr` tool, which
# extracts text from scanned PDFs and images. It must accept image inputs, so set
# vision = true. Point it at a strong OCR vision model, e.g. Gemini Flash or
# Qwen2.5-VL via OpenRouter. Without it, the tool falls back to the default model
# (when that model is vision-capable). Digital PDFs with a real text layer are
# read directly and never touch this model.
[models.ocr]
display_name = "OCR"
description = "Vision model used by the OCR tool for scanned documents and images."
slug = "google/gemini-2.5-flash"
provider = "openrouter"
vision = true

[server]
# SQLite database path. Used when `db_url` (below) is unset.
db_path = "/tmp/server.db"
# Full database connection URL, taking precedence over `db_path`. Supports
# sqlite, postgres, and postgresql schemes. Can also be set via the
# STRIDE_DATABASE_URL environment variable.
#   db_url = "postgres://user:password@localhost:5432/stride"
listen_addr = "0.0.0.0:3000"
# Self-signup is closed by default; set this to true to explicitly enable it.
allow_registration = false
# Public base URL the server is reachable at. When set, image attachments are
# served to vision models via capability URLs under this host instead of being
# embedded inline as base64.
public_url = "https://stride.example.com"

# Default agent behavior for users who have not saved their own settings in
# the web UI. Updating this rolls out new subagent routing guidance to those
# users without overwriting anyone who clicked Save in Settings → Models.
[server.agent]
default_subagent_guidelines = """
Use fast/cheap models for quick lookups, formatting, and narrow edits.
Use stronger models for multi-step reasoning, refactors, and ambiguous tasks.
Prefer vision-capable models when images are involved.
"""

# Set STRIDE_EMAIL_ENCRYPTION_KEY to a stable, high-entropy secret before users add IMAP accounts.
# It encrypts stored IMAP passwords and must remain stable across restarts and JWT key rotation.

[server.files]
keep_versions = 10

[server.files.local]
enabled = true
base = "/tmp/stride-files"

# Account linking uses the Telegram Login Widget (https://core.telegram.org/bots/telegram-login).
# Tell BotFather which domain hosts the widget with `/setdomain` (the host in `public_url`),
# otherwise Telegram refuses to render the login button.
# Each field may also be supplied via an environment variable, which takes over
# when the field is unset: STRIDE_TELEGRAM_BOT_API_KEY, STRIDE_TELEGRAM_BOT_USERNAME,
# STRIDE_TELEGRAM_WEBHOOK_SECRET, STRIDE_TELEGRAM_WEBHOOK_URL.
[server.telegram]
bot_api_key = "123456:telegram-bot-token"
bot_username = "stride_bot"
webhook_secret = "change-this-webhook-secret"
# Public HTTPS URL Telegram posts updates to. Required for the server to register
# the webhook on startup (with callback_query updates, so inline button taps work).
webhook_url = "https://stride.example.com/api/telegram/webhook"

# The hosted GitHub MCP server is available to every user who links an account.
# Users can always link by pasting a Personal Access Token in settings, so this
# whole section is optional. Configure an OAuth App only if you also want the
# one-click "Sign in with GitHub" flow: register one at
# https://github.com/settings/developers with the authorization callback URL set
# to `{public_url}/api/settings/github/callback`, then set client_id and
# client_secret below.
[server.github]
client_id = "Iv1.0123456789abcdef"
client_secret = "change-this-github-oauth-secret"
# Optional. OAuth scopes requested when linking; defaults to "repo read:org read:user".
# scopes = "repo read:org read:user"
# Optional. Override only for GitHub Enterprise Cloud; defaults to the official server.
# mcp_url = "https://api.githubcopilot.com/mcp/"

# Linking a Google account uses a standard OAuth 2.0 / OpenID Connect client.
# Create one in the Google Cloud console with the redirect URI set to
# `{public_url}/api/settings/google/callback`, and enable the Gmail, Calendar,
# and Drive APIs. Setting client_id and client_secret activates the native
# Gmail/Calendar/Drive tools and the Gmail automation trigger for linked users.
[server.google]
client_id = "0123456789-abcdef.apps.googleusercontent.com"
client_secret = "change-this-google-oauth-secret"
# Optional. OAuth scopes requested when linking. Defaults to OIDC identity plus
# Gmail modify (read + draft; nothing here sends mail), Calendar events, and
# read-only Drive.
# scopes = "openid email profile https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/drive.readonly"

[server.ldap]
url = "ldap://localhost:389"
user_dn_template = "uid={username},ou=users,dc=example,dc=com"

[tools.web_search]
searxng_endpoint = "https://search.example.com"
searxng_request_delay_seconds = 5
brave_api_key = "BSA..."
include_arxiv = true
include_pubmed = true

[tools.firecrawl]
api_key = "fc-..."
api_url = "https://api.firecrawl.dev"

[mcp.deepwiki]
url = "https://mcp.deepwiki.com/mcp"

[mcp.internal]
url = "https://mcp.example.com/mcp"
token = "secret-token"
headers = { X-Tenant = "acme" }

[tools.python]
enabled = true
cache_dir = "/tmp/stride-execenv"
backend = "Eryx"
threads = 2
preinit = true
max_runtime_seconds = 30
max_memory_bytes = 134217728
network = "Blocked"
