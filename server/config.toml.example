[providers.openai]
kind = "OpenAI"
url = "https://api.openai.com/v1"
token = "sk-..."

[providers.anthropic]
kind = "Anthropic"
url = "https://api.anthropic.com/v1"
token = "sk-ant-..."

[providers.ollama]
kind = "Ollama"
url = "http://localhost:11434/v1"

[models.gpt_4_1]
slug = "gpt-4.1"
provider = "openai"
thinking = true

[models.claude_sonnet_4]
