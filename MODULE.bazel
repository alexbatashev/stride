crate.spec(
    features = ["transport"],
    package = "tonic",
    version = "0.14.5",
)
crate.spec(
    package = "tonic-prost",
    version = "0.14.5",
)
crate.spec(
    package = "prost",
    version = "0.14.3",
)
crate.spec(
    package = "prost-types",
    version = "0.14.3",
)
crate.spec(
    package = "protoc-gen-prost",
    version = "0.5",
)
crate.annotation(
    crate = "protoc-gen-prost",
    gen_binaries = ["protoc-gen-prost"],
)
